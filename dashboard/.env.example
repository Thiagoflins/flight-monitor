# Copie este arquivo para .env.local para rodar localmente apontando para um CSV remoto.
# Sem essas variáveis, o dashboard lê o arquivo local em ../data/history.csv (modo dev).

# URL "raw" do history.csv no GitHub, ex:
# https://raw.githubusercontent.com/<usuario>/<repo>/main/data/history.csv
HISTORY_CSV_URL=

# Necessário apenas se o repositório for PRIVADO. Gere um token em
# https://github.com/settings/tokens (escopo "repo" de leitura é suficiente).
# NUNCA commite o valor real — use .env.local (ignorado pelo git) ou os
# "Environment Variables" do projeto na Vercel.
GITHUB_TOKEN=
